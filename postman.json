{
  "info": {
    "name": "Book Library API",
    "description": "Acceptance tests for Book Library web service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "POST /books - Add Book",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"title\":\"The Lord of the Rings\",\"author\":\"J.R.R. Tolkien\",\"isbn\":\"0395974682\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/books",
          "host": ["{{baseUrl}}"],
          "path": ["books"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has correct fields', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.title).to.eql('The Lord of the Rings');",
              "    pm.expect(jsonData.author).to.eql('J.R.R. Tolkien');",
              "    pm.expect(jsonData.isbn).to.eql('0395974682');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /books/:isbn - Retrieve Book",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/books/0395974682",
          "host": ["{{baseUrl}}"],
          "path": ["books", "0395974682"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Book matches stored data', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.title).to.eql('The Lord of the Rings');",
              "    pm.expect(jsonData.author).to.eql('J.R.R. Tolkien');",
              "    pm.expect(jsonData.isbn).to.eql('0395974682');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /books/:isbn - Not Found",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/books/9999999999",
          "host": ["{{baseUrl}}"],
          "path": ["books", "9999999999"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /books - List All Books",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/books",
          "host": ["{{baseUrl}}"],
          "path": ["books"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /books - Missing Fields (Negative)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"title\":\"Incomplete Book\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/books",
          "host": ["{{baseUrl}}"],
          "path": ["books"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
